MYSQL_DSN=marketplace:marketplace@tcp(127.0.0.1:3306)/octo_marketplace?charset=utf8mb4&parseTime=true
OCTO_API_URL=http://127.0.0.1:5001
API_PORT=8092
# External URL used in local-storage upload/download redirects. May include a gateway prefix.
PUBLIC_BASE_URL=http://127.0.0.1:8092
# Comma-separated browser origins allowed to read API responses.
# Leave empty by default; set explicitly in browser-facing deployments.
# CORS_ALLOWED_ORIGINS=https://octo.example.com,https://admin.octo.example.com
AUTH_ENABLED=false
AUTH_CACHE_TTL=30s
AUTH_CACHE_CAPACITY=10000
DEV_AUTH_UID=dev-user
DEV_AUTH_NAME=Developer
DEV_SPACE_ID=dev-space
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
# Keep false for shared deployments. Set true only when trusted MCP servers
# intentionally run on private or loopback addresses.
PROBE_ALLOW_PRIVATE=false
SKIP_MIGRATION=false

# Skill archive storage driver: "local" for local filesystem, "oss" for S3-compatible.
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=/tmp/marketplace-uploads

# S3-compatible object storage for Skill archives.
OSS_ENDPOINT=https://cos.region.myqcloud.com
OSS_REGION=region
OSS_BUCKET=bucket-name
OSS_KEY_PREFIX=example-prefix
OSS_PATH_STYLE=false
# Optional public-read CDN/custom domain used for unsigned downloads and signed uploads.
OSS_PUBLIC_ENDPOINT=https://cdn.example.com
# Public download URL style. Default false means virtual-host/custom-domain style:
#   https://cdn.example.com/environment/marketplace/skills/demo.zip
# Set true for path-style public endpoints such as local MinIO:
#   http://127.0.0.1:29000/bucket-name/environment/marketplace/skills/demo.zip
OSS_PUBLIC_PATH_STYLE=false
# Expected origin host used by signed uploads; requests fail closed on mismatch.
OSS_SIGNING_HOST=bucket-name.cos.region.myqcloud.com
# Set true to sign download URLs; false returns the public CDN object URL.
OSS_DOWNLOAD_SIGNED=false
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
MAX_UPLOAD_MB=20

# S3-compatible object storage for MCP icons (independent of skill storage above).
# When STORAGE_BUCKET (or endpoint/keys) is empty the icon upload endpoint
# POST /api/v1/mcps/{id}/icon is disabled; the rest of the service runs normally.
# STORAGE_ENDPOINT=http://127.0.0.1:9000
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET=octo-marketplace
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_PUBLIC_BASE_URL=https://cdn.example.com/octo-marketplace
# STORAGE_ICON_PARTITION=mcp
# STORAGE_PATH_STYLE=true

# Local docker-compose MinIO credentials. Override these in .env.
MINIO_ROOT_USER=octo-local-admin
MINIO_ROOT_PASSWORD=change-me-local-minio-password
